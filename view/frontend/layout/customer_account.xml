<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Customer\Block\Account\SortLinkInterface"
                   name="customer-account-navigation-passkeys-link"
                   ifconfig="passkey_auth/general/enabled">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Passkeys</argument>
                    <argument name="path" xsi:type="string">passkey/account</argument>
                    <argument name="sortOrder" xsi:type="number">175</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
