<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="passkey_challenge_cleanup"
             instance="MageOS\PasskeyAuth\Cron\ChallengeCleanup"
             method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
    </group>
</config>
