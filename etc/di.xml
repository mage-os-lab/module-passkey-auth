<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Data interfaces -->
    <preference for="MageOS\PasskeyAuth\Api\Data\CredentialInterface"
                type="MageOS\PasskeyAuth\Model\Data\Credential"/>

    <!-- Repository -->
    <preference for="MageOS\PasskeyAuth\Api\CredentialRepositoryInterface"
                type="MageOS\PasskeyAuth\Model\CredentialRepository"/>

    <!-- Registration services -->
    <preference for="MageOS\PasskeyAuth\Api\RegistrationOptionsInterface"
                type="MageOS\PasskeyAuth\Model\Registration\OptionsGenerator"/>
    <preference for="MageOS\PasskeyAuth\Api\RegistrationVerifierInterface"
                type="MageOS\PasskeyAuth\Model\Registration\Verifier"/>

    <!-- Authentication services -->
    <preference for="MageOS\PasskeyAuth\Api\AuthenticationOptionsInterface"
                type="MageOS\PasskeyAuth\Model\Authentication\OptionsGenerator"/>
    <preference for="MageOS\PasskeyAuth\Api\AuthenticationVerifierInterface"
                type="MageOS\PasskeyAuth\Model\Authentication\Verifier"/>
    <preference for="MageOS\PasskeyAuth\Api\Data\AuthenticationResultInterface"
                type="MageOS\PasskeyAuth\Model\Data\AuthenticationResult"/>

    <!-- Credential management -->
    <preference for="MageOS\PasskeyAuth\Api\CredentialManagementInterface"
                type="MageOS\PasskeyAuth\Model\CredentialManagement"/>
</config>
